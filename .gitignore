# build outputs
bin/
obj/
out/
dist/
*.pck
!assets/**/*.pck

# Godot import cache (regenerated on demand)
godot_project/.godot/

# Godot
.godot/
.import/
export.cfg
export_credentials.cfg

# IDE
.vs/
.idea/
*.user
*.suo

# referenced game/mod DLLs are local-only
src/lib/*.dll
src/lib/*.pdb

# secrets — never commit
.env
.env.*
*.key
nexus_api_key*
